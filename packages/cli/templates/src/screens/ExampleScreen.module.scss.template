.exampleScreen {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 40px;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 40px;
}

.title {
  font-size: 48px;
  font-weight: 400;
  margin: 0 0 10px;
}

.subtitle {
  font-size: 24px;
  margin: 0;
  opacity: 0.8;
}

.features {
  flex: 1;
}
